# 복지로 공공데이터 키 (data.go.kr). 없으면 캐시로 폴백한다.
DATA_GO_KR_KEY=

# true 이면 라이브 호출을 건너뛰고 캐시만 사용한다.
USE_MOCK=false

# --- LLM (핵심) ---
# Our Real Trip(ggui)과 동일 규약. 이 키만 넣으면 LLM이 자동으로 켜진다.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# 모델 (선택, 기본 gpt-4o)
OPENAI_MODEL=gpt-4o

# LLM 강제 OFF (템플릿만 사용). 끄려면 none.
# LLM_PROVIDER=none
# 상황 입력까지 LLM으로 분석하려면 true (기본 off — 데모 응답 속도 보호).
# LLM_ANALYZE=true
